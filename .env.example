ORBITYPE_MOCK=true

# Orbitype CMS (seed scripts + server API):
# ORBITYPE_API_SQL_URL="https://core.orbitype.com/api/sql/v1"
# ORBITYPE_API_SQL_KEY="your-api-key"

# Orbitype MCP (optional, used in .mcp.json / .cursor/mcp.json):
# ORBITYPE_S3_PUBLIC_API_KEY="your-s3-mcp-key"

# Orbitype form submissions (server-only, never NUXT_PUBLIC_):
# ORBITYPE_FORM_WEBHOOK_URL="https://core.orbitype.com/workflows/webhook?webhookSecret=YOUR_SECRET"

# Figma (design context + comments API):
# FIGMA_API_KEY="your-figma-personal-access-token"
# FIGMA_FILE_KEY="6Y050apOpdpZ3ZeVFdjunk"

# WordPress REST API (one-shot blog import):
# WP_API_URL="https://www.zofingen-treuhand.ch"
# WP_API_USERNAME="your-wp-user"
# WP_API_PASSWORD="your-application-password"

# Public SEO / branding settings:
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
NUXT_PUBLIC_SITE_NAME="Orbitype Headless CMS Template"
NUXT_PUBLIC_SITE_DESCRIPTION="A production-ready starter for Orbitype-powered websites."
NUXT_PUBLIC_ORGANIZATION_NAME="Orbitype"
NUXT_PUBLIC_ORGANIZATION_LOGO="/favicon.svg"
NUXT_PUBLIC_SITE_LOCALE="en_US"
NUXT_PUBLIC_TWITTER_SITE="@orbitype"
NUXT_PUBLIC_TWITTER_CREATOR="@orbitype"
NUXT_PUBLIC_OG_IMAGE_ENABLED="true"
NUXT_PUBLIC_COMMENTS_ENABLED="false"
NUXT_PUBLIC_OG_LOGO_PATH="/favicon.svg"
# Optional GTM container (empty disables GTM script injection):
NUXT_PUBLIC_GTM_ID=""
